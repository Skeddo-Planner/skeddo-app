#!/bin/bash
# ============================================================
# Skeddo pre-commit hook — smart data quality pipeline
#
# Automatically installed via: git config core.hooksPath .husky
#
# What this does:
#   1. If programs.json changed → runs the smart validation pipeline
#      (pre-commit-validate.cjs) which:
#        a. Identifies only new/changed programs
#        b. Auto-fixes computed fields and rule violations
#        c. Tries offline auto-resolution for remaining violations
#        d. BLOCKS only if new/changed programs still have violations
#        e. ALLOWS with a warning if violations are on pre-existing programs
#   2. If DATA-QUALITY-RULES.md changed but validate-programs.cjs
#      did NOT → warns that rules need corresponding code
#   3. Runs check-rules-coverage.cjs and prints coverage %
# ============================================================

# Find repo root (works in main worktree AND in git worktrees)
ROOT="$(git rev-parse --show-toplevel)"

# Collect staged file paths
STAGED="$(git diff --cached --name-only 2>/dev/null || true)"

PROGRAMS_CHANGED=false
SCRIPTS_CHANGED=false
RULES_DOC_CHANGED=false
VALIDATOR_CHANGED=false

while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    src/data/programs.json)        PROGRAMS_CHANGED=true ;;
    scripts/validate-programs.cjs) VALIDATOR_CHANGED=true; SCRIPTS_CHANGED=true ;;
    scripts/*)                     SCRIPTS_CHANGED=true ;;
    docs/DATA-QUALITY-RULES.md)    RULES_DOC_CHANGED=true ;;
  esac
done <<< "$STAGED"

EXIT_CODE=0

# ── Check 0: audit: commits require a verification log ──────────────────────────
COMMIT_MSG_FILE="$(git rev-parse --git-dir)/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG="$(cat "$COMMIT_MSG_FILE")"
else
  COMMIT_MSG=""
fi

# Check if this is an audit commit that touches programs.json
IS_AUDIT_COMMIT=false
case "$COMMIT_MSG" in
  audit:*) IS_AUDIT_COMMIT=true ;;
esac

if [ "$IS_AUDIT_COMMIT" = "true" ] && [ "$PROGRAMS_CHANGED" = "true" ]; then
  # Check that at least one docs/VERIFICATION-LOG-*.md is staged
  VERIFICATION_LOG_STAGED=false
  while IFS= read -r file; do
    case "$file" in
      docs/VERIFICATION-LOG-*.md) VERIFICATION_LOG_STAGED=true; break ;;
    esac
  done <<< "$STAGED"

  if [ "$VERIFICATION_LOG_STAGED" = "false" ]; then
    echo ""
    echo "┌──────────────────────────────────────────────────────────────────────┐"
    echo "│  ERROR: Provider audit commits require a verification log.           │"
    echo "│  Create docs/VERIFICATION-LOG-[PROVIDER].md before committing.       │"
    echo "│                                                                      │"
    echo "│  Stage the file with: git add docs/VERIFICATION-LOG-<provider>.md   │"
    echo "└──────────────────────────────────────────────────────────────────────┘"
    echo ""
    EXIT_CODE=1
  fi
fi

# ── Check 1: programs.json changed → smart validation pipeline ──────────────────
if [ "$PROGRAMS_CHANGED" = "true" ]; then
  echo ""
  echo "🔍 programs.json staged — running smart validation pipeline..."

  if node "$ROOT/scripts/pre-commit-validate.cjs" 2>&1; then
    echo "✅ Validation passed. Commit allowed."
  else
    # pre-commit-validate.cjs already printed the detailed error
    EXIT_CODE=1
  fi
fi

# ── Check 2: Rules doc changed but validator was NOT touched ─────────────────
if [ "$RULES_DOC_CHANGED" = "true" ] && [ "$VALIDATOR_CHANGED" = "false" ]; then
  echo ""
  echo "┌──────────────────────────────────────────────────────────┐"
  echo "│  ⚠️  WARNING: DATA-QUALITY-RULES.md was updated but      │"
  echo "│     validate-programs.cjs was NOT changed.               │"
  echo "│                                                          │"
  echo "│  Per Rule 17: every rule must be documented AND          │"
  echo "│  automated. Verify all new/changed rules have a          │"
  echo "│  corresponding check in validate-programs.cjs.           │"
  echo "│                                                          │"
  echo "│  Run: node scripts/check-rules-coverage.cjs              │"
  echo "└──────────────────────────────────────────────────────────┘"
  echo ""
  # Warning only — does not block commit
fi

# ── Check 3: Rules coverage report ──────────────────────────────────────────
if [ "$PROGRAMS_CHANGED" = "true" ] || \
   [ "$RULES_DOC_CHANGED" = "true" ] || \
   [ "$VALIDATOR_CHANGED" = "true" ] || \
   [ "$SCRIPTS_CHANGED" = "true" ]; then

  echo ""
  echo "📊 Running rules coverage check..."
  echo ""

  if node "$ROOT/scripts/check-rules-coverage.cjs" 2>&1; then
    : # coverage output already printed, exit 0 = good
  else
    echo ""
    echo "⚠️  Coverage gaps detected (see report above)."
    echo "   This is a WARNING — your commit will still proceed."
    echo "   Fix gaps before merging to main."
    echo ""
    # Do NOT block on coverage gaps — only data violations block commits
  fi
fi

echo ""
if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ Commit blocked. Fix the violations above, then try again."
fi

exit $EXIT_CODE
