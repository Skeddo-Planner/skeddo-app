# Sentry error monitoring — add these to Vercel's Environment Variables
# Sign up free at https://sentry.io, create a React project, then copy the values below.

# DSN from: Sentry project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Auth token from: https://sentry.io/settings/account/api/auth-tokens/
# Needs scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_xxxx

# Your Sentry organization slug (visible in the URL: sentry.io/organizations/<slug>/)
SENTRY_ORG=your-org-slug

# Your Sentry project slug (visible in: Settings → Projects → <project-name>)
SENTRY_PROJECT=skeddo
